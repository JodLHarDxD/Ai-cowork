{
  "name": "@jodl/tokens",
  "version": "0.0.1",
  "private": true,
  "description": "Design tokens — colors, typography, spacing, motion, z-index",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./colors": {
      "import": "./dist/colors.js",
      "types": "./dist/colors.d.ts"
    },
    "./typography": {
      "import": "./dist/typography.js",
      "types": "./dist/typography.d.ts"
    },
    "./spacing": {
      "import": "./dist/spacing.js",
      "types": "./dist/spacing.d.ts"
    },
    "./motion": {
      "import": "./dist/motion.js",
      "types": "./dist/motion.d.ts"
    },
    "./css": "./dist/tokens.css"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.0"
  }
}
